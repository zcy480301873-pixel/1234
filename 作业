<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>个人GIS作品集 | 双变量地图 | 标注编辑器 | GitHub Pages部署</title>
    <!-- Leaflet 核心 -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.js"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.css" />
    <!-- Font Awesome & Google Font -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background: #1a2a32; overflow: hidden; }
        .portfolio-container { display: flex; width: 100vw; height: 100vh; }
        /* 左侧面板 */
        .info-panel {
            width: 320px; background: rgba(22, 34, 48, 0.94); backdrop-filter: blur(12px);
            color: #eef4ff; display: flex; flex-direction: column; z-index: 20;
            border-right: 1px solid rgba(255,255,255,0.2); overflow-y: auto;
            box-shadow: 4px 0 20px rgba(0,0,0,0.3);
        }
        .panel-header { padding: 24px 20px 16px; border-bottom: 1px solid rgba(255,255,255,0.2); }
        .panel-header h1 { font-size: 1.7rem; display: flex; align-items: center; gap: 10px; }
        .panel-header h1 i { color: #4caf7f; }
        .section-title { font-size: 1rem; font-weight: 600; margin: 20px 20px 12px; border-left: 4px solid #4caf7f; padding-left: 12px; }
        .feature-list { margin: 0 20px 20px; list-style: none; }
        .feature-list li { margin: 8px 0; display: flex; align-items: center; gap: 10px; font-size: 0.85rem; }
        .data-card { background: rgba(0,0,0,0.3); margin: 0 20px 20px; border-radius: 16px; padding: 12px 16px; }
        .legend-item { display: flex; align-items: center; margin: 6px 0; font-size: 0.75rem; }
        .legend-color { width: 20px; height: 14px; border-radius: 4px; margin-right: 8px; }
        .legend-circle { width: 14px; height: 14px; border-radius: 50%; margin-right: 8px; }
        .btn-group { display: flex; gap: 10px; margin: 10px 20px 20px; }
        .btn-sm { background: rgba(76, 175, 127, 0.7); border: none; color: white; padding: 6px 12px; border-radius: 30px; cursor: pointer; font-size: 0.75rem; transition: 0.2s; }
        .btn-sm:hover { background: #4caf7f; transform: scale(1.02); }
        .map-wrapper { flex: 1; position: relative; }
        #map { width: 100%; height: 100%; background: #0e1a24; }
        .coord-status { position: absolute; bottom: 20px; left: 20px; background: rgba(0,0,0,0.6); padding: 4px 12px; border-radius: 20px; font-size: 11px; color: #ddd; z-index: 1000; pointer-events: none; }
        .map-tools-info { position: absolute; bottom: 20px; right: 20px; background: rgba(0,0,0,0.65); backdrop-filter: blur(8px); padding: 6px 14px; border-radius: 40px; color: white; font-size: 12px; z-index: 1000; }
        /* 标注编辑弹窗样式 */
        .custom-marker-editor {
            background: white; border-radius: 16px; padding: 12px; min-width: 200px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3); font-family: 'Inter', sans-serif;
        }
        .custom-marker-editor input, .custom-marker-editor textarea {
            width: 100%; margin: 5px 0; padding: 6px; border: 1px solid #ccc; border-radius: 8px;
        }
        .custom-marker-editor button { margin-top: 6px; background: #4caf7f; color: white; border: none; padding: 6px 12px; border-radius: 20px; cursor: pointer; }
        .leaflet-popup-content-wrapper { border-radius: 12px; }
    </style>
</head>
<body>
<div class="portfolio-container">
    <div class="info-panel">
        <div class="panel-header">
            <h1><i class="fas fa-map-marked-alt"></i> GIS作品集</h1>
            <p>双变量地图 · 标注编辑器 · 个人足迹</p>
        </div>
        <div class="section-title"><i class="fas fa-chart-line"></i> 双变量专题图</div>
        <div class="data-card">
            <div class="legend-item"><div class="legend-color" style="background:#fee5d9;"></div> 活动指数低 (0-3)</div>
            <div class="legend-item"><div class="legend-color" style="background:#fcae91;"></div> 中低 (3-5)</div>
            <div class="legend-item"><div class="legend-color" style="background:#fb6a4a;"></div> 中高 (5-8)</div>
            <div class="legend-item"><div class="legend-color" style="background:#cb181d;"></div> 高 (>8)</div>
            <div class="legend-item"><div class="legend-circle" style="background:#2c6e9e;"></div> 圆点大小 → 兴趣点密度</div>
            <p style="font-size:11px; margin-top:8px;">🎨 颜色+尺寸双变量编码区域特征</p>
        </div>
        <div class="section-title"><i class="fas fa-edit"></i> 标注编辑器</div>
        <div class="data-card">
            <p style="font-size:12px">✏️ 点击地图任意位置 → 添加自定义标注<br>📝 可编辑名称 / 描述 / 图标颜色<br>💾 自动保存到浏览器本地存储</p>
            <button id="exportGeoJSONBtn" class="btn-sm" style="margin-top:8px;"><i class="fas fa-download"></i> 导出标注为GeoJSON</button>
            <button id="clearAllMarksBtn" class="btn-sm" style="margin-top:5px;"><i class="fas fa-trash-alt"></i> 清除所有标注</button>
        </div>
        <div class="btn-group">
            <button id="saveViewBtn" class="btn-sm"><i class="fas fa-bookmark"></i> 保存当前视图</button>
            <button id="clearMeasureBtn" class="btn-sm"><i class="fas fa-ruler"></i> 清除测距</button>
        </div>
        <div class="btn-group">
            <button id="filterHighBtn" class="btn-sm"><i class="fas fa-filter"></i> 高频兴趣点 (≥5)</button>
            <button id="resetFilterBtn" class="btn-sm"><i class="fas fa-undo-alt"></i> 重置过滤</button>
        </div>
        <div style="text-align:center; font-size:11px; margin:16px 0 20px;">🚀 已部署 | GitHub Pages 就绪</div>
    </div>
    <div class="map-wrapper">
        <div id="map"></div>
        <div class="coord-status" id="coordStatus">📍 纬度: -- , 经度: --</div>
        <div class="map-tools-info" id="measureTip">📏 距离测量: 未测量</div>
    </div>
</div>

<script>
    // ---------- 1. 初始化地图 ----------
    const map = L.map('map').setView([39.9042, 116.4074], 11);
    const osm = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OSM' });
    const gaode = L.tileLayer('https://webrd02.is.autonavi.com/appmaptile?lang=zh_cn&size=1&scale=1&style=8&x={x}&y={y}&z={z}', { attribution: '高德地图' });
    const tianToken = '6e553a56f35f9aa1c679793ca3e5bab3';
    const tianditu = L.tileLayer(`https://t0.tianditu.gov.cn/vec_w/wmts?SERVICE=WMTS&REQUEST=GetTile&VERSION=1.0.0&LAYER=vec&STYLE=default&TILEMATRIXSET=w&FORMAT=tiles&TILEMATRIX={z}&TILEROW={y}&TILECOL={x}&tk=${tianToken}`, { attribution: '天地图' });
    osm.addTo(map);
    L.control.layers({ "OSM": osm, "高德影像": gaode, "天地图": tianditu }, null, { position: 'topright' }).addTo(map);
    L.control.scale({ metric: true, position: 'bottomleft' }).addTo(map);
    
    // 坐标显示
    map.on('mousemove', e => document.getElementById('coordStatus').innerHTML = `📍 纬度: ${e.latlng.lat.toFixed(5)} , 经度: ${e.latlng.lng.toFixed(5)}`);
    map.on('mouseout', () => document.getElementById('coordStatus').innerHTML = '📍 纬度: -- , 经度: --');
    
    // ---------- 2. 个人足迹 ----------
    const travelPoints = [[39.9042,116.4074,"北京"],[31.2304,121.4737,"上海"],[30.2741,120.1552,"杭州"],[30.5728,104.0668,"成都"],[34.3416,108.9398,"西安"],[39.9042,116.4074,"北京"]];
    L.polyline(travelPoints.map(p=>[p[0],p[1]]), { color: '#ff6b6b', weight: 3, dashArray: '8,8' }).addTo(map).bindPopup('🚶 个人足迹路线');
    travelPoints.forEach(p => L.marker([p[0],p[1]], { icon: L.divIcon({ html: '<i class="fas fa-map-marker-alt" style="color:#ff6b6b; font-size:22px;"></i>', iconSize: [22,22] }) }).addTo(map).bindPopup(`<b>${p[2]}</b><br>足迹记录`));
    
    // ---------- 3. 兴趣点（模拟访问次数）----------
    const poiList = [
        { coords:[39.9358,116.4565], name:"望京小街", type:"书店", visits:9, icon:"fas fa-book", color:"#8e44ad" },
        { coords:[39.9139,116.3978], name:"角楼咖啡", type:"咖啡", visits:12, icon:"fas fa-mug-hot", color:"#b85c1a" },
        { coords:[39.9462,116.3256], name:"颐和园", type:"景点", visits:5, icon:"fas fa-camera", color:"#2c6e9e" },
        { coords:[39.8966,116.3704], name:"PageOne", type:"书店", visits:7, icon:"fas fa-store", color:"#1e6f5c" },
        { coords:[39.9562,116.3072], name:"中关村", type:"科技", visits:3, icon:"fas fa-microchip", color:"#2980b9" },
        { coords:[39.9128,116.4105], name:"王府井", type:"美食", visits:8, icon:"fas fa-utensils", color:"#e67e22" },
        { coords:[39.9845,116.3258], name:"奥林匹克森林", type:"户外", visits:4, icon:"fas fa-tree", color:"#27ae60" }
    ];
    let poiMarkers = [];
    poiList.forEach(p => {
        const marker = L.marker(p.coords, { icon: L.divIcon({ html: `<div style="background:${p.color}; width:32px; height:32px; border-radius:50%; display:flex; align-items:center; justify-content:center;"><i class="${p.icon}" style="color:white;"></i></div>`, iconSize:[32,32] }) }).addTo(map);
        marker.bindPopup(`<b>${p.name}</b><br>🏷️ ${p.type}<br>📊 打卡次数: ${p.visits}`);
        marker.properties = { visits: p.visits };
        poiMarkers.push(marker);
    });
    
    // ---------- 4. 双变量专题图 (区域分级颜色 + 密度比例符号) ----------
    const districts = [
        { name:"朝阳区", coords:[[116.43,39.93],[116.52,39.93],[116.52,39.87],[116.43,39.87]], index:9.2, density:22 },
        { name:"海淀区", coords:[[116.27,39.98],[116.38,39.98],[116.38,39.90],[116.27,39.90]], index:8.7, density:18 },
        { name:"东城区", coords:[[116.39,39.92],[116.43,39.92],[116.43,39.88],[116.39,39.88]], index:6.5, density:12 },
        { name:"西城区", coords:[[116.35,39.92],[116.39,39.92],[116.39,39.88],[116.35,39.88]], index:6.8, density:11 },
        { name:"丰台区", coords:[[116.27,39.87],[116.34,39.87],[116.34,39.82],[116.27,39.82]], index:4.3, density:7 },
        { name:"通州区", coords:[[116.63,39.92],[116.69,39.92],[116.69,39.86],[116.63,39.86]], index:3.1, density:5 }
    ];
    const getColor = idx => idx>=8?'#cb181d':idx>=6?'#fb6a4a':idx>=4?'#fcae91':'#fee5d9';
    districts.forEach(d => {
        L.polygon(d.coords, { color: 'white', weight: 1.5, fillColor: getColor(d.index), fillOpacity: 0.65 }).addTo(map).bindPopup(`<b>${d.name}</b><br>活动指数: ${d.index}<br>POI密度: ${d.density}`);
        // 双变量第二变量：圆点大小表示兴趣点密度
        L.circleMarker([(d.coords[0][0]+d.coords[2][0])/2, (d.coords[0][1]+d.coords[2][1])/2], { radius: 5 + d.density*0.5, color: '#2c6e9e', weight: 1, fillColor: '#2c6e9e', fillOpacity: 0.7 }).addTo(map).bindTooltip(`${d.name} 密度:${d.density}`);
    });
    
    // ---------- 5. 标注编辑器 (点击地图添加标注，支持编辑，localStorage) ----------
    let userMarkers = []; // 存储标注对象 { id, marker, name, desc, color }
    let nextId = 1;
    function saveMarkersToLocal() { localStorage.setItem('userMarkers', JSON.stringify(userMarkers.map(m => ({ id: m.id, latlng: m.marker.getLatLng(), name: m.name, desc: m.desc, color: m.color })))); }
    function loadMarkersFromLocal() {
        const data = localStorage.getItem('userMarkers');
        if(!data) return;
        JSON.parse(data).forEach(item => {
            addMarkerToMap(item.latlng.lat, item.latlng.lng, item.name, item.desc, item.color, item.id);
        });
    }
    function addMarkerToMap(lat, lng, name, desc, color, id = null) {
        const markerId = id || nextId++;
        const iconHtml = `<div style="background:${color}; width:30px; height:30px; border-radius:50%; display:flex; align-items:center; justify-content:center; border:2px solid white;"><i class="fas fa-pen" style="color:white; font-size:14px;"></i></div>`;
        const marker = L.marker([lat, lng], { icon: L.divIcon({ html: iconHtml, iconSize: [30,30], className: 'custom-marker' }) }).addTo(map);
        const popupContent = `
            <div style="min-width:160px;">
                <strong>📌 ${name}</strong><br>
                <span>${desc}</span><br>
                <button class="edit-marker-btn" data-id="${markerId}" style="background:#4caf7f; border:none; color:white; border-radius:20px; padding:2px 8px; margin-top:6px; cursor:pointer;">✏️ 编辑</button>
                <button class="delete-marker-btn" data-id="${markerId}" style="background:#e74c3c; border:none; color:white; border-radius:20px; padding:2px 8px; margin-top:6px; cursor:pointer;">🗑️ 删除</button>
            </div>
        `;
        marker.bindPopup(popupContent);
        marker.on('popupopen', () => {
            document.querySelector(`.edit-marker-btn[data-id="${markerId}"]`)?.addEventListener('click', () => openEditDialog(markerId, lat, lng, name, desc, color));
            document.querySelector(`.delete-marker-btn[data-id="${markerId}"]`)?.addEventListener('click', () => deleteMarker(markerId));
        });
        userMarkers.push({ id: markerId, marker, name, desc, color });
        saveMarkersToLocal();
    }
    function openEditDialog(id, lat, lng, oldName, oldDesc, oldColor) {
        const newName = prompt("编辑标注名称", oldName);
        if(newName === null) return;
        const newDesc = prompt("编辑描述", oldDesc);
        const newColor = prompt("图标颜色 (hex, 如 #ffaa33)", oldColor);
        const markerObj = userMarkers.find(m => m.id === id);
        if(markerObj) {
            markerObj.name = newName || markerObj.name;
            markerObj.desc = newDesc || markerObj.desc;
            markerObj.color = newColor || markerObj.color;
            // 重新生成图标
            const newIcon = L.divIcon({ html: `<div style="background:${markerObj.color}; width:30px; height:30px; border-radius:50%; display:flex; align-items:center; justify-content:center; border:2px solid white;"><i class="fas fa-pen" style="color:white;"></i></div>`, iconSize:[30,30] });
            markerObj.marker.setIcon(newIcon);
            markerObj.marker.setPopupContent(`<div><strong>📌 ${markerObj.name}</strong><br>${markerObj.desc}<br><button class="edit-marker-btn" data-id="${id}">编辑</button> <button class="delete-marker-btn" data-id="${id}">删除</button></div>`);
            saveMarkersToLocal();
            markerObj.marker.closePopup();
        }
    }
    function deleteMarker(id) {
        const idx = userMarkers.findIndex(m => m.id === id);
        if(idx !== -1) {
            map.removeLayer(userMarkers[idx].marker);
            userMarkers.splice(idx,1);
            saveMarkersToLocal();
        }
    }
    map.on('click', (e) => {
        const lat = e.latlng.lat, lng = e.latlng.lng;
        const name = prompt("请输入标注名称", "我的标注");
        if(!name) return;
        const desc = prompt("描述", "自定义地点");
        const color = prompt("图标颜色 (如 #3498db)", "#3498db");
        addMarkerToMap(lat, lng, name, desc, color);
    });
    document.getElementById('exportGeoJSONBtn').addEventListener('click', () => {
        const features = userMarkers.map(m => ({
            type: "Feature", properties: { name: m.name, description: m.desc, color: m.color },
            geometry: { type: "Point", coordinates: [m.marker.getLatLng().lng, m.marker.getLatLng().lat] }
        }));
        const geojson = { type: "FeatureCollection", features };
        const dataStr = JSON.stringify(geojson);
        const blob = new Blob([dataStr], {type: "application/json"});
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a'); a.href = url; a.download = "my_annotations.geojson"; a.click(); URL.revokeObjectURL(url);
    });
    document.getElementById('clearAllMarksBtn').addEventListener('click', () => {
        userMarkers.forEach(m => map.removeLayer(m.marker));
        userMarkers = [];
        saveMarkersToLocal();
    });
    loadMarkersFromLocal();
    
    // ---------- 6. 其他交互（书签，过滤，测距）----------
    let bookmarks = [];
    document.getElementById('saveViewBtn').addEventListener('click', () => {
        const c = map.getCenter(); const z = map.getZoom();
        bookmarks.push({ center: [c.lat, c.lng], zoom: z });
        alert(`视图已保存 (共${bookmarks.length}个)`);
        if(bookmarks.length===1) L.popup().setLatLng(c).setContent("📌 书签已保存，可通过控制台 bookmarks 访问").openOn(map);
    });
    function filterPOI(minVisits) { poiMarkers.forEach(m => { if(m.properties?.visits >= minVisits) map.addLayer(m); else map.removeLayer(m); }); }
    document.getElementById('filterHighBtn').addEventListener('click', () => filterPOI(5));
    document.getElementById('resetFilterBtn').addEventListener('click', () => poiMarkers.forEach(m => map.addLayer(m)));
    
    // 测距工具
    const drawnItems = new L.FeatureGroup(); map.addLayer(drawnItems);
    const drawControl = new L.Control.Draw({ position: 'topleft', draw: { polyline: { shapeOptions: { color: '#f357a1', weight: 4 }, metric: true }, polygon: false, circle: false, marker: false }, edit: { featureGroup: drawnItems } });
    map.addControl(drawControl);
    const measureDiv = document.getElementById('measureTip');
    map.on(L.Draw.Event.CREATED, e => {
        if(e.layer instanceof L.Polyline) {
            let dist=0; const pts=e.layer.getLatLngs();
            for(let i=0;i<pts.length-1;i++) dist+=pts[i].distanceTo(pts[i+1]);
            measureDiv.innerHTML = `📏 距离: ${dist>=1000?(dist/1000).toFixed(2)+' km':dist.toFixed(1)+' m'}`;
            drawnItems.addLayer(e.layer);
        }
    });
    map.on(L.Draw.Event.DELETED, () => { if(drawnItems.getLayers().length===0) measureDiv.innerHTML='📏 距离测量: 未测量'; });
    document.getElementById('clearMeasureBtn').addEventListener('click', () => { drawnItems.clearLayers(); measureDiv.innerHTML='📏 距离测量: 未测量'; });
    
    console.log("作品集已启动，支持双变量地图+标注编辑器+本地存储");
</script>
</body>
</html>
